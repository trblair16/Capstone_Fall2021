@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject AuthService AuthSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Manage Users — Camp Clot Not</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">User Accounts</MudText>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Create Account</MudText>
            <MudTextField @bind-Value="_form.DisplayName" Label="Display Name" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_form.Email" Label="Email" InputType="InputType.Email" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_form.Password" Label="Temporary Password" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect @bind-Value="_form.Role" Label="Role" Variant="Variant.Outlined" Class="mb-4">
                <MudSelectItem Value="UserRole.Staff">Staff / Volunteer</MudSelectItem>
                <MudSelectItem Value="UserRole.Admin">Admin</MudSelectItem>
                <MudSelectItem Value="UserRole.Display">Display (Projector)</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync">Create</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="7">
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudTable Items="_users" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.DisplayName</MudTd>
                    <MudTd>@context.Email</MudTd>
                    <MudTd><MudChip Size="Size.Small">@context.Role</MudChip></MudTd>
                    <MudTd>@(context.IsActive ? "✓" : "—")</MudTd>
                    <MudTd>
                        @if (context.IsActive)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small"
                                           Color="Color.Warning" OnClick="() => DeactivateAsync(context)"
                                           Title="Deactivate" />
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudItem>
</MudGrid>

@code {
    private List<User> _users = new();
    private bool _loading = true;
    private UserForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        _users = await AuthSvc.GetAllUsersAsync();
        _loading = false;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Email) || string.IsNullOrWhiteSpace(_form.Password)) return;
        await AuthSvc.CreateUserAsync(_form.DisplayName, _form.Email, _form.Password, _form.Role);
        Snackbar.Add($"Account created for {_form.DisplayName}.", Severity.Success);
        _form = new();
        _users = await AuthSvc.GetAllUsersAsync();
    }

    private async Task DeactivateAsync(User u)
    {
        var result = await DialogService.ShowMessageBox("Deactivate User",
            $"Deactivate {u.DisplayName}? They will no longer be able to sign in.",
            yesText: "Deactivate", cancelText: "Cancel");
        if (result != true) return;
        await AuthSvc.DeactivateUserAsync(u.UserId);
        _users = await AuthSvc.GetAllUsersAsync();
        Snackbar.Add($"{u.DisplayName} deactivated.", Severity.Info);
    }

    private class UserForm
    {
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public UserRole Role { get; set; } = UserRole.Staff;
    }
}
